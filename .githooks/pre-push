#!/usr/bin/env bash
set -euo pipefail

# pre-push hook: Block direct master pushes and verify build
# This enforces the worktree workflow and ensures code quality
#
# To bypass (emergency only): git push --no-verify

# Get the current branch name
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Block direct pushes to master/main
if [ "$CURRENT_BRANCH" = "master" ] || [ "$CURRENT_BRANCH" = "main" ]; then
  echo ""
  echo "ERROR: Direct push to '$CURRENT_BRANCH' is blocked."
  echo ""
  echo "This project requires the worktree workflow:"
  echo "  1. Create a worktree with a feature branch"
  echo "  2. Make changes in the worktree"
  echo "  3. Push the feature branch"
  echo "  4. Create a PR and merge via squash-and-merge"
  echo ""
  echo "To bypass (emergency only): git push --no-verify"
  exit 1
fi

echo "Running pre-push checks..."
echo "Verifying Xcode build-for-testing..."
echo ""
echo "NOTE: First push on a fresh clone may take 8-12 minutes while"
echo "DerivedData is populated. Subsequent pushes use warm cache (<1 min typical)."
echo ""

# Build the project including test targets to verify everything compiles.
# build-for-testing compiles OfflineMediaDownloaderTests and UITests alongside
# the main app, catching test-target compile errors before they reach CI.
# -skipMacroValidation bypasses Xcode's interactive macro approval requirement
# -skipPackagePluginValidation bypasses Swift package plugin approval
xcodebuild -project OfflineMediaDownloader.xcodeproj \
  -scheme OfflineMediaDownloader \
  -destination 'generic/platform=iOS Simulator' \
  -skipMacroValidation \
  -skipPackagePluginValidation \
  build-for-testing 2>&1 | tee /tmp/pre-push-build.log

BUILD_RESULT=${PIPESTATUS[0]}

if [ $BUILD_RESULT -ne 0 ]; then
  echo ""
  echo "ERROR: Xcode build-for-testing failed. Please fix build errors before pushing."
  echo ""
  echo "To bypass (emergency only): git push --no-verify"
  exit 1
fi

# Mirror CI's warnings-as-errors behavior
WARNING_COUNT=$(grep -c 'warning:' /tmp/pre-push-build.log || true)
if [ "$WARNING_COUNT" -gt 0 ]; then
  echo ""
  echo "ERROR: Build succeeded but produced $WARNING_COUNT warning(s)."
  echo "CI treats warnings as errors (-warnings-as-errors). Fix them before pushing."
  echo ""
  grep 'warning:' /tmp/pre-push-build.log | head -20
  echo ""
  echo "To bypass (emergency only): git push --no-verify"
  exit 1
fi

echo ""
echo "Build successful (zero warnings). Proceeding with push."
exit 0
